# ═══════════════════════════════════════════════════════════════
# CedarGuard Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your real values.
# These MUST match what is configured in Vercel Dashboard →
#   Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════

# ──── Frontend (Vite — Exposed to Browser) ────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
VITE_API_URL=/api
VITE_GEMINI_API_KEY=your_gemini_api_key

# ──── Desktop Build (Electron) ────────────────────────────────
# Google OAuth Desktop Client ID — created at
# https://console.cloud.google.com/apis/credentials → Create Credentials →
# OAuth client ID → Application type: "Desktop app".
# The same Client ID MUST also be whitelisted in:
# Firebase Console → Authentication → Sign-in method → Google → "Whitelist
# client IDs from external projects" (paste this Client ID and Save) —
# otherwise Firebase rejects desktop sign-ins with INVALID_IDP_RESPONSE.
# Used only by the Electron desktop build; web ignores it.
VITE_GOOGLE_DESKTOP_CLIENT_ID=63265176715-8t53cbqntcq4pva81ai150u5karntoej.apps.googleusercontent.com

# Google OAuth Desktop Client Secret — shown alongside the Client ID when the
# Desktop OAuth client is created. Per Google's official docs: "The process
# results in a client ID and, in some cases, a client secret, which you embed
# in the source code of your application. (In this context, the client secret
# is obviously not treated as a secret.)" — Desktop clients require this in
# the token-exchange request. Format: GOCSPX-...
# If you've lost it: GCP Console → Credentials → click CedarGuard Desktop →
# Reset secret (note this invalidates the old one).
VITE_GOOGLE_DESKTOP_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──── macOS Code Signing + Notarisation (CI build secrets, NOT for .env.local) ─
# These light up the dormant signing config in electron-builder.yml. When set,
# `npm run dist:mac` produces a signed + notarised DMG that opens cleanly on
# any Mac (no right-click → Open). When unset (current dev behaviour), DMG
# builds unsigned. Belong in CI secrets / GitHub Actions, NOT in dev .env.local.
#
# Procurement: $99/yr Apple Developer Program → enroll →
# https://developer.apple.com/account/resources/certificates → create a
# "Developer ID Application" certificate.
APPLE_ID=you@example.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx    # appleid.apple.com → App-Specific Passwords
APPLE_TEAM_ID=ABCDE12345                            # 10-char team ID
CSC_NAME="Developer ID Application: Your Name (ABCDE12345)"
CSC_LINK=                                           # base64-encoded .p12 OR file:// path to .p12
CSC_KEY_PASSWORD=                                   # .p12 password

# Vercel API base URL the desktop binary calls (absolute https URL).
# Required only for the desktop build — web uses the relative /api fallback.
VITE_DESKTOP_API_URL=https://cedarguard.co.uk

# ──── Backend (Vercel Serverless Functions — Server Only) ─────
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/...","universe_domain":"googleapis.com"}
GEMINI_API_KEY=your_gemini_api_key

# ──── Optional ─────────────────────────────────────────────────
# Comma-separated emails that get system admin access
SYSTEM_ADMIN_EMAILS=admin@yourdomain.com
# Comma-separated allowed CORS origins
CORS_ALLOWED_ORIGINS=https://cedarguard.co.uk,https://www.cedarguard.co.uk
