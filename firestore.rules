rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================
    // CedarGuard Compliance & Risk Manager – Firestore Rules
    // =====================================================
    // NOTE: All production data access flows through the
    // backend API (Vercel serverless function using Firebase
    // Admin SDK), which bypasses these rules. These rules
    // serve as a defence-in-depth layer for any direct
    // client SDK access and for development/testing.
    // =====================================================

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isClientAdminOrAbove() {
      return isAdmin() || hasRole('client_admin');
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Users can read their own profile; admins can read any
      allow read: if isOwner(userId) || isAdmin();
      // Users can create their own profile on first login
      allow create: if isOwner(userId);
      // Users can update their own profile; admins can update any
      allow update: if isOwner(userId) || isAdmin();
      // Only admins can delete user records
      allow delete: if isAdmin();

      // User sub-collections (preferences, legacy data)
      match /data/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- Projects Collection ---
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isClientAdminOrAbove();

      // Project sub-collections (compliance, risks, issues, KRIs, etc.)
      match /data/{document=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // --- Programmes Collection ---
    match /programmes/{programmeId} {
      allow read: if isSignedIn();
      allow create: if isClientAdminOrAbove();
      allow update: if isSignedIn();
      allow delete: if isClientAdminOrAbove();
    }

    // --- Evidence Collection ---
    match /evidence/{evidenceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // --- Invitations Collection ---
    match /invitations/{invitationId} {
      allow read: if isSignedIn();
      allow create: if isClientAdminOrAbove();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- API Keys Collection ---
    match /apiKeys/{keyId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // --- Activity Logs Collection ---
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false; // Immutable audit log
    }

    // --- System Mappings Collection ---
    match /systemMappings/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Global Risks Collection ---
    match /globalRisks/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Compliance Library Collection ---
    match /complianceLibrary/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Compliance Domains Collection ---
    match /complianceDomains/{domainId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Invoices Collection ---
    match /invoices/{invoiceId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- Pricing Config ---
    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // =====================================================
    // Programme Governance — v1 collections
    // =====================================================
    // All writes go through the backend (Firebase Admin SDK) which
    // bypasses these rules. Client SDK writes are blocked. Reads are
    // allowed for signed-in users; server-side code enforces the
    // per-clientId tenancy scoping.

    // Framework + bodies + ToR + authority thresholds
    match /frameworks/{frameworkId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /governanceBodies/{bodyId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /termsOfReference/{torId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Forward Plan
    match /forwardPlanItems/{itemId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Report templates + report instances + review artefacts
    match /reportTemplates/{templateId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow write: if false;

      // Section content + immutable version snapshots live as sub-collections
      match /sections/{sectionId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
      match /sectionVersions/{versionId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }
    match /amendments/{amendmentId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /reportComments/{commentId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /signatures/{signatureId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /chaseEvents/{chaseId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Meetings + per-project meeting attendance
    match /meetings/{meetingId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /meetingAttendance/{attendanceId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Per-project governance docs (decision logs, ToR acknowledgements, etc.)
    match /projectGovernanceDocs/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Export jobs (weekly FP export, framework PDF export, audit export)
    match /exportJobs/{jobId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Phase 1 editor sandbox — per-user scratch area for the standalone
    // editor test page. Server writes only (Firebase Admin bypasses).
    match /_governanceSandbox/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;

      match /sections/{sectionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }
    }

    // Immutable streams — server-only, no client writes EVER (even admin)
    match /auditEvents/{eventId} {
      allow read: if isAdmin() || isClientAdminOrAbove();
      allow write: if false;
    }
    match /goldenThread/{recordId} {
      allow read: if isAdmin() || isClientAdminOrAbove();
      allow write: if false;
    }

    // --- Deny all unmatched paths ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
